# =============================================
# Platzhalter - Local Development Environment
# Copy this to .env and adjust values as needed
# =============================================

# --- PostgreSQL ---
DB_HOST=/tmp
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=
DB_DATABASE=platzhalter
DB_SSLMODE=disable

# --- Database URL (used by application code, connects over TCP) ---
DATABASE_URL=postgresql://your_username@localhost:5432/platzhalter?sslmode=disable

# --- SMTP (Mailpit) ---
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@platzhalter.local

# --- Mailpit UI ---
MAILPIT_UI_PORT=8025

# --- Backend ---
BACKEND_PORT=8080
BACKEND_HOST=127.0.0.1

# --- Frontend ---
FRONTEND_PORT=3000

# --- Auth / JWT ---
JWT_SECRET=change-me
BETTER_AUTH_SECRET=change-me

# --- General ---
APP_ENV=development
